# ─────────────────────────────────────────────
#  AEH API Server — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server Port (required)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# ── Database ──────────────────────────────────
# Option 1: Neon PostgreSQL (takes priority if set)
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Option 2: Local PostgreSQL (fallback)
DATABASE_URL=postgresql://postgres:password@localhost:5432/aeh_db

# ── JWT Secrets ───────────────────────────────
# Use a long random string for production (min 32 chars recommended)
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
SESSION_SECRET=change_this_too

# ── Razorpay (Test Mode) ──────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (optional) ───────────────────────────
# Comma-separated list of allowed origins
# Use * to allow all (not recommended in production)
ALLOWED_ORIGINS=http://localhost:21165,http://localhost:3000
